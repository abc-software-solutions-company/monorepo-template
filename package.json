{
  "name": "turborepo-template",
  "private": true,
  "scripts": {
    "build": "dotenv -e .env.production turbo build",
    "dev": "dotenv -e .env.local turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "test": "turbo test",
    "test:cov": "turbo test:cov",
    "format": "turbo format",
    "check:format": "turbo check:format",
    "check:types": "turbo check:types",
    "clean": "rimraf {apps,packages}/**/{node_modules,dist,.next,.turbo} -g && rimraf node_modules",
    "postinstall": "manypkg check && cd apps/react-native-app/ios && pod install",
    "prepare": "husky",
    "api": "turbo dev --filter=api-admin",
    "admin": "turbo dev --filter=admin-portal",
    "app": "turbo dev --filter=next-app",
    "mobile:ios": "yarn workspace react-native-app ios",
    "mobile:android": "yarn workspace react-native-app android"
  },
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "dependencies": {
    "@manypkg/cli": "^0.21.4",
    "@repo/config-prettier": "*",
    "@repo/config-typescript": "*",
    "@repo/eslint-config": "*",
    "dotenv-cli": "^7.4.2",
    "husky": "^9.0.11",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "turbo": "^2.0.6"
  }
}
