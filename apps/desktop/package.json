{
  "name": "desktop",
  "private": true,
  "version": "0.0.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"cross-env DEV= tsc-watch -p tsconfig-electron.json --onSuccess \\\"electron .\\\"\"",
    "preview": "vite build && tsc -p tsconfig-electron.json && cross-env PREVIEW= electron .",
    "build": "vite build && tsc -p tsconfig-electron.json && electron-forge make",
    "check:format": "prettier --check .",
    "check:types": "tsc --pretty --noEmit",
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@repo/react-web-ui-shadcn": "*",
    "@repo/shared-universal": "*",
    "@repo/shared-web": "*",
    "concurrently": "^9.1.2",
    "electron-squirrel-startup": "^1.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^6.0.4",
    "@electron-forge/maker-deb": "^6.0.4",
    "@electron-forge/maker-rpm": "^6.0.4",
    "@electron-forge/maker-squirrel": "^6.0.4",
    "@electron-forge/maker-zip": "^6.0.4",
    "@eslint/js": "^9.19.0",
    "@repo/config-prettier": "*",
    "@repo/config-tailwindcss": "*",
    "@repo/config-typescript": "*",
    "@repo/eslint-config": "*",
    "@types/electron": "^1.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "cross-env": "^7.0.3",
    "electron": "^34.1.1",
    "eslint": "8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "tsc-watch": "^6.2.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0"
  }
}
