{
  "extends": "@repo/config-typescript/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tests/*": ["./__tests__/*"],
      "@mocks/*": ["./__mocks__/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.tsx",
    "**/*.ts",
    "types",
    "__tests__",
    "__mocks__",
    "../../packages/react-web-ui-shadcn/src",
    "../../packages/shared-universal/src",
    "../../packages/shared-web/src"
  ],
  "exclude": ["node_modules"]
}
