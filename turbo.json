{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", ".env"],
  "globalEnv": [
    "NODE_ENV",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_MESSENGER_PAGE_ID",
    "NEXT_PUBLIC_GOOGLE_TRACKING",
    "NEXT_PUBLIC_SEGMENT_TRACKING",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_APP_ENV",
    "NEXTAUTH_URL",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_EXPIRES_IN",
    "AUTH_GOOGLE_ID",
    "AUTH_GOOGLE_SECRET",
    "AUTH_FACEBOOK_ID",
    "AUTH_FACEBOOK_SECRET",
    "HOST",
    "PORT",
    "REQUEST_TIMEOUT",
    "THROTTLE_TTL",
    "THROTTLE_LIMIT",
    "CACHE_TIME_TO_LIVE",
    "AP_DB_SSL",
    "AP_DB_HOST",
    "AP_DB_PORT",
    "AP_DB_NAME",
    "AP_DB_USERNAME",
    "AP_DB_PASSWORD",
    "DB_SCHEMA",
    "AP_DB_LOGS",
    "REDIS_HOST",
    "REDIS_PORT",
    "JWT_SECRET_KEY",
    "JWT_EXPIRES_IN",
    "JWT_REFRESH_SECRET_KEY",
    "JWT_REFRESH_EXPIRES_IN",
    "OAUTH_FACEBOOK_CLIENT_ID",
    "OAUTH_FACEBOOK_CLIENT_SECRET",
    "OAUTH_GOOGLE_CLIENT_ID",
    "OAUTH_GOOGLE_CLIENT_SECRET",
    "EMAIL_HOST",
    "EMAIL_PORT",
    "EMAIL_SECURE",
    "EMAIL_USERNAME",
    "EMAIL_PASSWORD",
    "DOCUMENTATION_ENABLED",
    "ADMIN_USER_EMAIL",
    "ADMIN_USER_PASSWORD",
    "AWS_ENDPOINT",
    "AWS_REGION",
    "AWS_ACCESS_KEY_ID",
    "AWS_SECRET_ACCESS_KEY",
    "AWS_S3_BUCKET_NAME",
    "FIREBASE_UNIVERSE_DOMAIN",
    "VITE_PUBLIC_API_URL",
    "FIREBASE_CONFIG"
  ],
  "tasks": {
    "lint": { "dependsOn": ["^lint"] },
    "lint:fix": { "dependsOn": ["^lint:fix"] },
    "format": { "dependsOn": ["^format"] },
    "check:format": { "dependsOn": ["^check:format"] },
    "check:types": { "dependsOn": ["^check:types"] },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env.production.local", ".env.local", ".env.production", ".env"]
    },
    "dev": { "cache": false, "persistent": true, "inputs": ["$TURBO_DEFAULT$", ".env.development.local", ".env.local", ".env.development", ".env"] },
    "test": { "inputs": ["$TURBO_DEFAULT$", ".env.test.local", ".env.test", ".env"] },
    "test:cov": { "dependsOn": ["^test:cov"] },
    "prepare": { "dependsOn": ["^prepare"] },
    "setup": { "dependsOn": ["^setup"] }
  }
}
