{
  "extends": "@repo/config-typescript/react-library.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "target": "ESNext",
    "module": "ESNext",
    "paths": {
      "@/*": ["./src/*"],
      "@repo/shared-universal/*": ["../shared-universal/src/*"],
      "@repo/shared-web/*": ["../shared-web/src/*"]
    }
  },
  "include": ["src", "../shared-universal/src", "../shared-web/src"],
  "exclude": ["node_modules"]
}
